# Lege diese Datei als .env ins Monorepo-Root (ibm-agentic-ai-/), nicht nur unter apps/prototyp-1-v2.
#
# Sicherheit: Niemals echte Keys in Chat, Tickets oder Git committen. War ein LangSmith-Key je
# öffentlich sichtbar → in LangSmith (Settings → API Keys) einen neuen Key erstellen und den alten widerrufen.
#
# LangSmith (server-side only – NEVER prefix with VITE_)
LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY_HERE
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
#
# Multi-Workspace (optional): Nur setzen, wenn derselbe API-Key mehreren LangSmith-Workspaces zugeordnet ist.
# Workspace-ID findest du in LangSmith unter Settings / Workspace. Der Vite-Dev-Proxy und die Vercel-Route
# api/langsmith setzen daraus den Header x-tenant-id. Wenn du nur einen Workspace hast, leer lassen.
# LANGSMITH_WORKSPACE_ID=
#
# Falls der Browser-Client den Tenant-Header selbst mitschicken muss (selten), zusätzlich:
# VITE_LANGSMITH_WORKSPACE_ID=

# LangSmith browser config (safe to expose – no secrets)
VITE_LANGSMITH_PROXY=true
VITE_LANGSMITH_PROJECT=HSG Agentic
