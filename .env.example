# Lege diese Datei als .env ins Monorepo-Root (ibm-agentic-ai-/), nicht nur unter apps/prototyp-1-v2.
#
# LangSmith (server-side only – NEVER prefix with VITE_)
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# LangSmith browser config (safe to expose – no secrets)
VITE_LANGSMITH_PROXY=true
VITE_LANGSMITH_PROJECT=Asklepios_agent
