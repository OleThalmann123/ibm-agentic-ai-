# Lege diese Datei als .env ins Monorepo-Root (ibm-agentic-ai-/), nicht nur unter apps/prototyp-1-v2.
#
# Sicherheit: Niemals echte Keys in Chat, Tickets oder Git committen.

# ── LangSmith (wie offizielle Doku: https://docs.langchain.com/langsmith ) ──
# Server: Key nur hier oder in Vercel – niemals VITE_LANGSMITH_API_KEY nutzen.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY_HERE
LANGSMITH_PROJECT=HSG Agentic
# Optional (ältere LangChain-Doku): nur nötig, wenn du ohne VITE_LANGSMITH_PROXY / LANGSMITH_TRACING arbeitest
# LANGSMITH_TRACING_V2=true
# LANGCHAIN_TRACING_V2=true
#
# Multi-Workspace (optional):
# LANGSMITH_WORKSPACE_ID=

# OpenRouter (App ruft Modelle darüber auf)
# VITE_OPENROUTER_API_KEY=…

# ── Browser / Vite (öffentlich im Bundle – keine Secrets) ──
# Expliziter Proxy-Modus (empfohlen): API-Key bleibt auf dem Server / im Vite-Dev-Proxy.
VITE_LANGSMITH_PROXY=true
# Optional, wenn LANGSMITH_PROJECT gesetzt: kann weggelassen werden (wird aus LANGSMITH_PROJECT übernommen).
# VITE_LANGSMITH_PROJECT=HSG Agentic
#
# VITE_LANGSMITH_WORKSPACE_ID=  # nur wenn Client x-tenant-id selbst setzen soll

# ── Betrieb ──
# - Vite ersetzt LANGSMITH_TRACING / LANGSMITH_PROJECT / LANGSMITH_ENDPOINT zur Build-Zeit
#   (siehe apps/prototyp-1-v2/vite.config.ts define). Nach Änderung: Dev neu starten / Vercel redeploy.
# - `import { traceable } from "langsmith/traceable"` aus der Doku ist Node-only (async_hooks);
#   diese App nutzt LangChainTracer + RunTree im Browser – gleiches Ziel, anderes API.
# - npm run preview: kein Vite-Proxy für /api/langsmith.
